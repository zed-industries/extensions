          "keyword.control.import": { "color": "#bb9af7", "font_weight": 700 },
          "keyword.operator": { "color": "#f7768e" },
          "keyword.operator.comparison": {
            "color": "#ffb347",
            "font_weight": 700
          },
          "keyword.operator.logical": {
            "color": "#9ece6a",
            "font_weight": 700
          },
          "keyword.operator.assignment": {
            "color": "#7aa2f7",
            "font_weight": 700
          },

          "storage": { "color": "#bb9af7", "font_weight": 700 },

          "function": { "color": "#7aa2f7", "font_style": "italic" },

          "type": { "color": "#b4f9f8" },

          "variable": { "color": "#eee8d5" },
          "variable.parameter": { "color": "#e0afaf" },
          "variable.special": { "color": "#bb9af7" },

          "property": { "color": "#b4f9f8", "font_weight": 700 },

          "operator": { "color": "#f7768e" },
          "operator.special": { "color": "#f7768e", "font_weight": 700 },
          "punctuation": { "color": "#eee8d5" },
          "punctuation.bracket": { "color": "#ffffff" },
          "punctuation.delimiter": { "color": "#eee8d5" },
          "punctuation.list_marker": { "color": "#ffffff" },
          "punctuation.special": { "color": "#f7768e" },
          "embedded": { "color": "#e0afaf" },

          "constant": { "color": "#ff9e64", "font_weight": 700 },
          "boolean": { "color": "#ff9e64" },
          "number": { "color": "#ff9e64" },

          "tag": { "color": "#7aa2f7" },
          "attribute": { "color": "#bb9af7", "font_style": "italic" },

          "selector": { "color": "#ff9e64", "font_weight": 700 },

          "namespace": { "color": "#eee8d5" },
          "namespace.wildcard": { "color": "#f7768e", "font_weight": 700 },
          "constructor": { "color": "#7aa2f7" },
          "enum": { "color": "#b4f9f8" },
          "label": { "color": "#bb9af7" },
          "preproc": { "color": "#bb9af7" },

          "link_text": { "color": "#b4f9f8", "font_style": "normal" },
          "link_uri": { "color": "#7aa2f7" },

          "predictive": { "color": "#4a3b5c", "font_style": "italic" },
          "primary": { "color": "#eee8d5" },

          "markup.heading": { "color": "#bb9af7", "font_weight": 700 },
          "markup.bold": { "color": "#7aa2f7", "font_weight": 700 },
          "markup.italic": { "color": "#ff9e64", "font_style": "italic" },
          "markup.list": { "color": "#eee8d5" },
          "markup.list.bullet": { "color": "#4a3b5c", "font_weight": 700 },
          "markup.link": { "color": "#b4f9f8", "font_style": "normal" },
          "markup.raw": { "color": "#9ece6a" },
          "markup.quote": { "color": "#6b6080", "font_style": "italic" },
          "string.json": { "color": "#ffb48a" },
          "property.json": { "color": "#b4f9f8", "font_weight": 700 },

          "hint": { "color": "#7aa2f7" },
          "title": { "color": "#bb9af7", "font_weight": 700 },

          "diff.plus": { "color": "#9ece6a" },
          "diff.minus": { "color": "#f7768e" }
