        "terminal.ansi.dim_black": "#17131d",
        "terminal.ansi.red": "#f7768e",
        "terminal.ansi.bright_red": "#f7768e",
        "terminal.ansi.dim_red": "#a0445a",
        "terminal.ansi.green": "#9ece6a",
        "terminal.ansi.bright_green": "#9ece6a",
        "terminal.ansi.dim_green": "#5f8a3a",
        "terminal.ansi.yellow": "#ff9e64",
        "terminal.ansi.bright_yellow": "#ff9e64",
        "terminal.ansi.dim_yellow": "#a06030",
        "terminal.ansi.blue": "#7aa2f7",
        "terminal.ansi.bright_blue": "#7aa2f7",
        "terminal.ansi.dim_blue": "#4060a0",
        "terminal.ansi.magenta": "#bb9af7",
        "terminal.ansi.bright_magenta": "#bb9af7",
        "terminal.ansi.dim_magenta": "#7050a0",
        "terminal.ansi.cyan": "#b4f9f8",
        "terminal.ansi.bright_cyan": "#b4f9f8",
        "terminal.ansi.dim_cyan": "#508a8a",
        "terminal.ansi.white": "#eee8d5",
        "terminal.ansi.bright_white": "#ffffff",
        "terminal.ansi.dim_white": "#a09090",

        "syntax": {
          "comment": { "color": "#6b6080", "font_style": "italic" },
          "comment.doc": { "color": "#7a7090", "font_style": "italic" },

          "string": { "color": "#ff9e64" },
          "string.escape": { "color": "#ffb347" },
          "string.regex": { "color": "#ff9e64" },
          "string.special": { "color": "#ffb347" },
          "string.special.symbol": { "color": "#ffb347" },

          "keyword": { "color": "#bb9af7", "font_weight": 700 },
          "keyword.control": {
            "color": "#ff9e64",
            "font_style": "italic",
            "font_weight": 700
