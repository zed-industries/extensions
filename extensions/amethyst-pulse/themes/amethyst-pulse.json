          {
            "cursor": "#f7768e",
            "background": "#f7768e",
            "selection": "#f7768e3d"
          },
          {
            "cursor": "#ff9e64",
            "background": "#ff9e64",
            "selection": "#ff9e643d"
          },
          {
            "cursor": "#9ece6a",
            "background": "#9ece6a",
            "selection": "#9ece6a3d"
          },
          {
            "cursor": "#7aa2f7",
            "background": "#7aa2f7",
            "selection": "#7aa2f73d"
          },
          {
            "cursor": "#b4f9f8",
            "background": "#b4f9f8",
            "selection": "#b4f9f83d"
          },
          {
            "cursor": "#e0afaf",
            "background": "#e0afaf",
            "selection": "#e0afaf3d"
          },
          {
            "cursor": "#ffb347",
            "background": "#ffb347",
            "selection": "#ffb3473d"
          }
