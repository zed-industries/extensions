        "editor.selection": "#4a3b5c80",
        "editor.selection.border": "#bb9af7",

        "link_text.hover": "#bb9af7",

        "version_control.added": "#9ece6a",
        "version_control.modified": "#ff9e64",
        "version_control.deleted": "#f7768e",

        "conflict": "#ff9e64",
        "conflict.background": "#ff9e641a",
        "conflict.border": "#4a3b2f",
        "created": "#9ece6a",
        "created.background": "#9ece6a1a",
        "created.border": "#2f4a2f",
        "deleted": "#f7768e",
        "deleted.background": "#f7768e1a",
        "deleted.border": "#4a2b2e",
        "error": "#f7768e",
        "error.background": "#f7768e1a",
        "error.border": "#4a2b2e",
        "hidden": "#6b6080",
        "hidden.background": "#1e1a241a",
        "hidden.border": "#312a3d",
        "hint": "#7aa2f7",
        "hint.background": "#7aa2f71a",
        "hint.border": "#2b3b5c",
        "ignored": "#6b6080",
        "ignored.background": "#1e1a241a",
        "ignored.border": "#2d283a",
        "info": "#7aa2f7",
        "info.background": "#7aa2f71a",
        "info.border": "#2b3b5c",
        "modified": "#ff9e64",
        "modified.background": "#ff9e641a",
        "modified.border": "#4a3b2f",
        "predictive": "#4a3b5c",
        "predictive.background": "#2d24381a",
        "predictive.border": "#312a3d",
        "renamed": "#bb9af7",
        "renamed.background": "#bb9af71a",
        "renamed.border": "#4a3b5c",
        "success": "#9ece6a",
        "success.background": "#9ece6a1a",
        "success.border": "#2f4a2f",
        "unreachable": "#6b6080",
        "unreachable.background": "#1e1a241a",
        "unreachable.border": "#2d283a",
        "warning": "#ff9e64",
        "warning.background": "#ff9e641a",
        "warning.border": "#4a3b2f",

        "players": [
          {
            "cursor": "#bb9af7",
            "background": "#bb9af7",
            "selection": "#bb9af73d"
