{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Amethyst Pulse",
  "author": "Jonh Sousa",
  "themes": [
    {
      "name": "Amethyst Pulse",
      "appearance": "dark",
      "style": {
        "background": "#1a1620",
        "surface.background": "#211d27",
        "elevated_surface.background": "#252030",

        "border": "#2d283a",
        "border.variant": "#241f30",
        "border.focused": "#bb9af7",
        "border.selected": "#4a3b5c",
        "border.transparent": "#00000000",
        "border.disabled": "#312a3d",

        "element.background": "#282330",
        "element.hover": "#3d334d",
        "element.active": "#6b4fa0",
        "element.selected": "#2d2438",
        "element.disabled": "#1e1a24",
        "drop_target.background": "#bb9af780",

        "ghost_element.background": "#00000000",
        "ghost_element.hover": "#282330",
        "ghost_element.active": "#5a3d8a",
        "ghost_element.selected": "#2d2438",
        "ghost_element.disabled": "#1e1a24",

        "text": "#eee8d5",
        "text.muted": "#6b6080",
        "text.placeholder": "#4a3b5c",
        "text.disabled": "#4a3b5c",
        "text.accent": "#bb9af7",

        "icon": "#eee8d5",
        "icon.muted": "#6b6080",
        "icon.disabled": "#4a3b5c",
        "icon.placeholder": "#6b6080",
        "icon.accent": "#bb9af7",

        "status_bar.background": "#1a1620",
        "title_bar.background": "#1a1620",
        "title_bar.inactive_background": "#17131d",
        "toolbar.background": "#1e1a24",
